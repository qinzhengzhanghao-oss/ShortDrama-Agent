            "character": "narrator",
            "text": "林远坐在电脑前，屏幕的蓝光映在他疲惫的脸上。电话铃声突然响起。林远看了一眼来电显示，犹豫了一下，接起电话。"
          },
          {
            "character": "李明",
            "text": "林远，我是李明。听说你在做新方案？我想跟你谈谈合作的事。"
          },
          {
            "character": "林远",
            "text": "李总？您不是已经……"
          },
          {
            "character": "李明",
            "text": "过去的事不提了。明天下午三点，老地方见。"
          },
          {
            "character": "narrator",
            "text": "电话挂断。林远盯着手机屏幕，眉头紧锁。"
          }
        ]
      },
      {
        "sceneId": 2,
        "location": "咖啡馆",
        "summary": "林远提前到达咖啡馆，李明随后到来，两人沉默后李明表态。",
        "characters": [
          "林远",
          "李明"
        ],
        "parsed": true,
        "dialogue": [
          {
            "character": "narrator",
            "text": "林远提前十分钟到了咖啡馆。他选了一个靠窗的位置。李明推门进来，径直走向林远的桌子。"
          },
          {
            "character": "李明",
            "text": "好久不见。"
          },
          {
            "character": "林远",
            "text": "确实。"
          },
          {
            "character": "narrator",
            "text": "两人沉默了几秒。李明要了一杯美式。"
          },
          {
            "character": "李明",
            "text": "我知道你恨我。但这次我是认真的。"
          }
        ]
      }
